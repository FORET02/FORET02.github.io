---
const SHOW_AFTER_PX = 400; 
---

<button
  id="back-to-top"
  class="btt"
  type="button"
  aria-label="Back to top"
  title="Back to top"
>
  <svg class="btt__icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path
      d="M12 5l-7 7 1.4 1.4L11 8.8V20h2V8.8l4.6 4.6L19 12z"
      fill="currentColor"
    />
  </svg>
</button>

<script is:inline>
  (() => {
    const mount = () => {
      const btn = document.getElementById("back-to-top");
      if (!btn) return;

      if (!btn.dataset.bound) {
        btn.addEventListener("click", () => {
          const reduce =
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;

          window.scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
        });
        btn.dataset.bound = "1";
      }

      const setVisible = () => {
        const show = window.scrollY > ${SHOW_AFTER_PX};
        btn.dataset.show = show ? "1" : "0";
      };

      if (!window.__bttScrollBound) {
        window.__bttScrollBound = true;
        window.addEventListener(
          "scroll",
          () => {
            const el = document.getElementById("back-to-top");
            if (!el) return;
            const show = window.scrollY > ${SHOW_AFTER_PX};
            el.dataset.show = show ? "1" : "0";
          },
          { passive: true }
        );
      }

      setVisible();
    };

    document.addEventListener("astro:page-load", mount);
    mount();
  })();
</script>

<style>
  .btt {
    position: fixed;
    right: 18px;
    bottom: 22px; 
    z-index: 50;

    width: 44px;
    height: 44px;
    border-radius: 9999px;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    background: var(--bg, rgba(255, 255, 255, 0.9));
    border: 1px solid rgba(15, 23, 42, 0.12);
    color: var(--primary, #14b8a6);

    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(10px);

    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .btt[data-show="1"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .btt:hover {
    box-shadow: 0 14px 38px rgba(15, 23, 42, 0.12);
    transform: translateY(-2px);
  }

  .btt:active {
    transform: translateY(0);
  }

  .btt:focus-visible {
    outline: 2px solid color-mix(in oklab, currentColor 35%, transparent);
    outline-offset: 3px;
  }

  :global(html.dark) .btt,
  :global(body.dark) .btt,
  :global(html[data-theme="dark"]) .btt,
  :global(body[data-theme="dark"]) .btt {
    background: rgba(2, 6, 23, 0.65);
    border-color: rgba(148, 163, 184, 0.22);
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .btt {
      transition: none;
    }
  }
</style>
