---
import BaseLayout from "../layouts/BaseLayout.astro";

import "../styles/home.css";
import "../styles/contact.css";
import "../styles/page-transitions.css";
import "../styles/theme.css";

import { siteConfig } from "../config/site";
---

<BaseLayout title="Get In Touch - Foret Blog">
  <main class="contact-page">
    <div class="contact-page-container page-content">
      <div class="contact-header contact-header-animate">
        <h1 class="contact-title">{siteConfig.contact.title}</h1>
        <p class="contact-subtitle">{siteConfig.contact.subtitle}</p>
      </div>

      <div class="contact-grid">
        <!-- Contact Info Card -->
        <div class="contact-card contact-card-animate">
          <h2 class="contact-card-title">Contact Info</h2>
          <div class="contact-info-list">
            <div class="contact-info-item">
              <div class="contact-icon-wrapper email-icon">
                <img src="/svg/email.svg" alt="email icon" class="contact-icon" />
              </div>
              <div class="contact-info-content">
                <div class="contact-info-label">{siteConfig.contact.info.email.label}</div>
                <a href={siteConfig.contact.info.email.link} class="contact-info-value">
                  {siteConfig.contact.info.email.value}
                </a>
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-icon-wrapper location-icon">
                <img src="/svg/location.svg" alt="location icon" class="contact-icon" />
              </div>
              <div class="contact-info-content">
                <div class="contact-info-label">{siteConfig.contact.info.location.label}</div>
                <div class="contact-info-value">{siteConfig.contact.info.location.value}</div>
              </div>
            </div>
          </div>

          <div class="contact-message-button-wrapper">
            <a href="/comments" class="contact-message-button">
              {siteConfig.contact.messageButton}
            </a>
          </div>
        </div>

        <!-- Follow Me Card -->
        <div class="contact-card contact-card-animate">
          <h3 class="contact-card-subtitle">{siteConfig.contact.followMe.title}</h3>
          <div class="social-icons-list">
            {siteConfig.contact.followMe.links.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="social-icon-link"
                title={social.name.toLowerCase()}
              >
                <img src={social.icon} alt={`${social.name} icon`} />
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="contact-footer-text comments-content-animate">
        {siteConfig.contact.footerText.map((text) => (
          <p>{text}</p>
        ))}
      </div>
    </div>
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const pageContent = document.querySelector(".page-content");
      if (pageContent) requestAnimationFrame(() => pageContent.classList.add("visible"));

      const header = document.querySelector(".contact-header-animate");
      if (header) requestAnimationFrame(() => header.classList.add("visible"));

      const cards = document.querySelectorAll(".contact-card-animate");
      cards.forEach((card) => requestAnimationFrame(() => card.classList.add("visible")));
    });
  </script>
</BaseLayout>
