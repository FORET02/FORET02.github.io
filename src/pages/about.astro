---
import "../styles/home.css";
import Navigation from "../components/Navigation.astro";
import "../styles/theme.css";
---

<html lang="ko">
  <head>
    <!-- ✅ Theme init (FOUC 방지) : 기본은 항상 light -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("theme"); // "light" | "dark" | null
          const theme =
            saved === "dark" || saved === "light" ? saved : "light"; // ✅ 기본 light

          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = "light";
          document.documentElement.style.colorScheme = "light";
        }
      })();
    </script>

    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>About Me - Foret Blog</title>
  </head>
  <body>
    <!-- Navigation -->
    <Navigation />

    <!-- About Me -->
    <section class="about-section">
      <div class="about-content">
        <h2 class="about-title">About Me</h2>
        <p class="about-text">
          Hello! I'm Someone, a passionate blogger and web developer. I love sharing my thoughts on technology, programming, and web development through this blog. With years of experience in the industry, I aim to provide valuable insights and tutorials to help others grow their skills. When I'm not coding or writing, I enjoy hiking, photography, and exploring new places. Thank you for visiting my blog, and I hope you find the content helpful and inspiring!
        </p>
      </div>
    </section>

    <!-- <div class="new-section"></div> -->

    <!-- Proficiency Card -->
    <!-- (주석 블록은 원본 그대로 유지) -->

    <!-- Footer -->
    <footer>
      <div class="footer-content">
        <div class="footer-text">
          © 2025 Someone. All rights reserved. • <a href="#" class="footer-link"
            >Privacy Policy</a
          >
          • <a href="#" class="footer-link">Terms of Service</a> • <a
            href="#"
            class="footer-link">Sitemap</a
          >
        </div>
        <a
          href="https://github.com/tomcomtang/astro-cartoon-portfolio"
          class="footer-github"
          >Star this project on Github</a
        >
      </div>
    </footer>
  </body>
</html>
