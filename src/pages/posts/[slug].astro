---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { getCollection, type CollectionEntry } from "astro:content";
import "../../styles/home.css";
import "../../styles/post-detail.css";
import "../../styles/page-transitions.css";
import "../../styles/theme.css";

type PostPath = {
  params: { slug: string };
  props: { post: any };
};

export async function getStaticPaths(): Promise<PostPath[]> {
  const posts = (await getCollection("posts")) as CollectionEntry<"posts">[];

  return posts
    .map((post: any) => {
      let slug = post.slug;

      if (!slug && post.id) {
        slug = post.id.split("/").pop()?.replace(/\.md$/, "") || "";
      }

      if (!slug) {
        console.warn("Post missing slug in getStaticPaths:", post);
        return null;
      }

      return {
        params: { slug },
        props: { post },
      };
    })
    .filter((v): v is PostPath => v !== null);
}

const { post } = Astro.props as { post: any };

if (!post) {
  throw new Error("Post is undefined");
}

function parseDateStable(value: unknown): Date {
  if (value instanceof Date) return value;

  const s = String(value ?? "").trim();
  const m = s.match(/^(\d{4})[\/-](\d{1,2})[\/-](\d{1,2})$/);

  if (m) {
    const y = Number(m[1]);
    const mo = Number(m[2]);
    const d = Number(m[3]);

    if (!Number.isFinite(y) || !Number.isFinite(mo) || !Number.isFinite(d)) {
      throw new Error(`Invalid date value: ${s}`);
    }

    return new Date(Date.UTC(y, mo - 1, d));
  }

  const dt = new Date(s);
  if (Number.isNaN(dt.getTime())) {
    throw new Error(`Invalid date value: ${s}`);
  }
  return dt;
}

// Format date to "YYYY년 M월 D일" in Korean locale (KST)
function formatDateText(dateValue: unknown): string {
  const d = parseDateStable(dateValue);
  return new Intl.DateTimeFormat("ko-KR", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "Asia/Seoul",
  }).format(d);
}

let ContentComponent: any = null;
let ContentHtml = "";

if (post && typeof post.render === "function") {
  const rendered = await post.render();
  ContentComponent = rendered?.Content ?? null;
} else if (post.rendered && typeof post.rendered === "object" && post.rendered.Content) {
  ContentComponent = post.rendered.Content;
} else if (post.body) {
  const { unified } = await import("unified");
  const remarkParse = (await import("remark-parse")).default;
  const remarkRehype = (await import("remark-rehype")).default;
  const rehypeStringify = (await import("rehype-stringify")).default;

  const processor = unified().use(remarkParse).use(remarkRehype).use(rehypeStringify);
  const result = await processor.process(post.body);
  ContentHtml = String(result);
} else {
  throw new Error(
    `Cannot find content in post. Available keys: ${Object.keys(post).join(", ")}`
  );
}

const title = String(post.data?.title ?? "Post");
const pageTitle = `${title} - Foret Blog`;

const author = String(post.data?.author || "Foret");
const readTime = String(post.data?.readTime || "");
const avatarSrc = "/image/pettydust.jpg";

const tags: string[] = Array.isArray(post.data?.tags) ? post.data.tags : [];
const dateValue = post.data?.date;
---

<BaseLayout title={pageTitle}>
  <main class="post-detail-page">
    <div class="post-detail-container page-content">
      <div class="post-header-card post-header-animate">
        <h1 class="post-detail-title">{title}</h1>

        {tags.length > 0 && (
          <div class="post-detail-tags">
            {tags.map((tag: string) => (
              <span class="post-detail-tag">{tag}</span>
            ))}
          </div>
        )}

        <div class="post-detail-meta">
          <a href="/posts" class="post-back-button">← Back to Posts</a>

          <div class="post-detail-meta-info">
            <img
              src={avatarSrc}
              alt={author}
              class="post-detail-avatar"
              loading="lazy"
              decoding="async"
            />
            <span class="post-detail-author">{author}</span>
            <span class="post-detail-date">{formatDateText(dateValue)}</span>
            {readTime && <span class="post-detail-read-time">{readTime}</span>}
          </div>
        </div>
      </div>

      <div class="post-content post-content-animate">
        {ContentComponent ? <ContentComponent /> : <div set:html={ContentHtml} />}
      </div>
    </div>
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const pageContent = document.querySelector(".page-content");
      if (pageContent) requestAnimationFrame(() => pageContent.classList.add("visible"));

      const header = document.querySelector(".post-header-animate");
      if (header) requestAnimationFrame(() => header.classList.add("visible"));

      const content = document.querySelector(".post-content-animate");
      if (content) requestAnimationFrame(() => content.classList.add("visible"));
    });
  </script>
</BaseLayout>
