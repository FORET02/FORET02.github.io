---
import { siteConfig } from "../config/site";

const currentPath = Astro.url.pathname;
---

<nav>
  <a href="/" class="site-name">{siteConfig.name}</a>
  <ul class="nav-menu">
    <li>
      <a href="/" class={`menu-link ${currentPath === "/" ? "active" : ""}`}
        >{siteConfig.navigation.home}</a
      >
    </li>
    <li>
      <a
        href="/posts"
        class={`menu-link ${currentPath.startsWith("/posts") ? "active" : ""}`}
        >{siteConfig.navigation.posts}</a
      >
    </li>
    <li>
      <a
        href="/contact"
        class={`menu-link ${currentPath.startsWith("/contact") ? "active" : ""}`}
        >{siteConfig.navigation.contact}</a
      >
    </li>
    <li>
      <a
        href="/comments"
        class={`menu-link ${currentPath.startsWith("/comments") ? "active" : ""}`}
        >{siteConfig.navigation.comments}</a
      >
    </li>

    <li class="theme-switch-item">
      <button
        type="button"
        class="theme-switch"
        data-theme-toggle
        role="switch"
        aria-checked="false"
        aria-label="Switch to dark mode"
        title="Switch theme"
      >
        <span class="theme-switch__thumb" aria-hidden="true">
          <svg
            class="theme-switch__icon theme-switch__icon--moon"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
          <svg
            class="theme-switch__icon theme-switch__icon--sun"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M4.93 19.07l1.41-1.41"></path>
            <path d="M17.66 6.34l1.41-1.41"></path>
          </svg>
        </span>
      </button>
    </li>
  </ul>
</nav>

<style>

  .theme-switch-item {
    display: flex;
    align-items: center;
  }

  .theme-switch {
    width: 46px;
    height: 26px;
    border-radius: 999px;

    background: var(--surface, rgba(255, 255, 255, 0.7));
    border: 1px solid var(--border, rgba(0, 0, 0, 0.12));

    padding: 2px;
    display: inline-flex;
    align-items: center;

    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .theme-switch__thumb {
    width: 22px;
    height: 22px;
    border-radius: 999px;

    background: var(--bg, #ffffff);
    border: 1px solid var(--border, rgba(0, 0, 0, 0.12));

    display: inline-flex;
    align-items: center;
    justify-content: center;

    color: var(--text, #111827);

    transition: transform 180ms ease;
    will-change: transform;
  }

  .theme-switch:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.25);
  }

  .theme-switch__icon--sun {
    display: none;
  }

  html[data-theme="dark"] .theme-switch__thumb {
    transform: translateX(20px);
  }
  html[data-theme="dark"] .theme-switch__icon--moon {
    display: none;
  }
  html[data-theme="dark"] .theme-switch__icon--sun {
    display: inline-block;
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-switch__thumb {
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const STORAGE_KEY = "theme";
    const root = document.documentElement;
    const btn = document.querySelector("[data-theme-toggle]");

    const normalize = (v) => (v === "dark" || v === "light" ? v : null);
    const getTheme = () => normalize(root.dataset.theme) ?? "light";

    const setA11y = (theme) => {
      if (!btn) return;
      const next = theme === "dark" ? "light" : "dark";
      const label =
        next === "dark" ? "Switch to dark mode" : "Switch to light mode";
      btn.setAttribute("aria-label", label);
      btn.setAttribute("title", label);
      btn.setAttribute("aria-checked", theme === "dark" ? "true" : "false");
    };

    const apply = (theme, persist) => {
      root.dataset.theme = theme;
      root.style.colorScheme = theme;
      if (persist) localStorage.setItem(STORAGE_KEY, theme);
      setA11y(theme);
    };

    const existing = normalize(root.dataset.theme);
    const saved = normalize(localStorage.getItem(STORAGE_KEY));
    const initial = existing ?? saved ?? "light";

    if (existing !== initial) {
      apply(initial, false); 
    } else {
      setA11y(initial);
    }

    btn?.addEventListener("click", () => {
      const now = getTheme();
      const next = now === "dark" ? "light" : "dark";
      apply(next, true);
    });

    const observer = new MutationObserver(() => setA11y(getTheme()));
    observer.observe(root, { attributes: true, attributeFilter: ["data-theme"] });
  })();
</script>
